    "eslint": "^8.50.0"
  },
  "peerDependencies": {
    "eslint": ">=8.43",
    "eslint-plugin-ava": ">=14.0.0",
    "eslint-plugin-markdown": ">=3.0.1"
  },
  "publishConfig": {
    "access": "public"
  }
